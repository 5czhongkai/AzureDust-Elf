# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=

# SiliconFlow / hybrid TTS
SILICONFLOW_API_KEY=
CONTENT_AGENT_OS_TTS_API_KEY=
CONTENT_AGENT_OS_TTS_PROVIDER=
CONTENT_AGENT_OS_TTS_MODEL=fnlp/MOSS-TTSD-v0.5
CONTENT_AGENT_OS_TTS_VOICE=

# Runtime
CONTENT_AGENT_ENV=local
CONTENT_AGENT_TIMEZONE=Asia/Shanghai
CONTENT_AGENT_OUTPUT_ROOT=outputs/runs
CONTENT_AGENT_BACKUP_ROOT=backups
CONTENT_AGENT_CONSOLE_HOST=127.0.0.1
CONTENT_AGENT_CONSOLE_PORT=8080
CONTENT_AGENT_CONSOLE_INLINE_JOBS=1
CONTENT_AGENT_JOB_RETENTION_DAYS=30
CONTENT_AGENT_AUDIT_RETENTION_DAYS=90
CONTENT_AGENT_PLATFORMS=wechat,xiaohongshu,douyin,shipinhao,bilibili
CONTENT_AGENT_TOPIC=AI内容创作自动化系统
CONTENT_AGENT_WORKER_ONCE=0
CONTENT_AGENT_WORKER_POLL_INTERVAL_SECONDS=5
CONTENT_AGENT_SCHEDULE_TOPIC=AI内容创作自动化系统
CONTENT_AGENT_SCHEDULE_INTERVAL_SECONDS=86400
CONTENT_AGENT_SCHEDULER_DRY_RUN=1
CONTENT_AGENT_SCHEDULER_ONCE=0

# Optional services for later phases
DATABASE_URL=sqlite:///data/content_agent_os.db
REDIS_URL=redis://redis:6379/0

# Platform credentials are intentionally not stored in repo files.
