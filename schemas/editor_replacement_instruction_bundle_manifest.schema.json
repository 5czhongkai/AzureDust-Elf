{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-agent-os.local/schemas/editor_replacement_instruction_bundle_manifest.schema.json",
  "title": "EditorReplacementInstructionBundleManifest",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "topic",
    "manifest_path",
    "video_production_package",
    "platforms",
    "source_artifacts",
    "platform_instructions",
    "export_boundary",
    "validation",
    "generation_status",
    "manual_review_required",
    "human_confirmation_required",
    "review_required"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "phase4.editor_replacement_instruction_bundle_manifest.v1" },
    "artifact_type": { "type": "string", "const": "editor_replacement_instruction_bundle" },
    "run_id": { "type": "string" },
    "topic": { "type": "string" },
    "manifest_path": { "type": "string", "const": "final/editor_replacement_instruction_manifest.json" },
    "video_production_package": { "type": "string", "const": "final/video_production_package.json" },
    "platforms": {
      "type": "array",
      "items": { "enum": ["douyin", "shipinhao", "bilibili"] }
    },
    "source_artifacts": { "type": "array", "items": { "type": "string" } },
    "platform_instructions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "platform",
          "platform_label",
          "manifest_path",
          "replacement_commands_path",
          "editor_import_template_path",
          "human_confirmation_checklist_path",
          "readme_path",
          "instruction_count",
          "ready_pending_human_confirmation_count",
          "pending_human_media_count",
          "blocked_instruction_count",
          "executable_after_human_confirmation_count",
          "human_confirmation_required_count",
          "validation",
          "source_artifacts",
          "review_required",
          "human_confirmation_required"
        ],
        "properties": {
          "platform": { "enum": ["douyin", "shipinhao", "bilibili"] },
          "platform_label": { "type": "string" },
          "manifest_path": { "type": ["string", "null"] },
          "replacement_commands_path": { "type": ["string", "null"] },
          "editor_import_template_path": { "type": ["string", "null"] },
          "human_confirmation_checklist_path": { "type": ["string", "null"] },
          "readme_path": { "type": ["string", "null"] },
          "instruction_count": { "type": "number" },
          "ready_pending_human_confirmation_count": { "type": "number" },
          "pending_human_media_count": { "type": "number" },
          "blocked_instruction_count": { "type": "number" },
          "executable_after_human_confirmation_count": { "type": "number" },
          "human_confirmation_required_count": { "type": "number" },
          "validation": { "type": "object", "additionalProperties": true },
          "source_artifacts": { "type": "array", "items": { "type": "string" } },
          "review_required": { "type": "boolean", "const": true },
          "human_confirmation_required": { "type": "boolean", "const": true }
        },
        "additionalProperties": false
      }
    },
    "export_boundary": {
      "type": "object",
      "required": [
        "editor_replacement_instructions",
        "replacement_execution",
        "editing_software",
        "project_file_mutation",
        "asset_download",
        "external_asset_search",
        "license_purchase",
        "publishing",
        "upload"
      ],
      "properties": {
        "editor_replacement_instructions": { "type": "string", "const": "performed_locally_template_and_instruction_only" },
        "replacement_execution": { "type": "string", "const": "not_performed" },
        "editing_software": { "type": "string", "const": "not_opened" },
        "project_file_mutation": { "type": "string", "const": "not_performed" },
        "asset_download": { "type": "string", "const": "not_performed" },
        "external_asset_search": { "type": "string", "const": "not_performed" },
        "license_purchase": { "type": "string", "const": "not_performed" },
        "publishing": { "type": "string", "const": "not_performed" },
        "upload": { "type": "string", "const": "not_performed" }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": [
        "status",
        "platform_count",
        "passed_platform_count",
        "instruction_count",
        "ready_pending_human_confirmation_count",
        "pending_human_media_count",
        "blocked_instruction_count",
        "executable_after_human_confirmation_count",
        "human_confirmation_required_count",
        "human_confirmation_gate_active",
        "replacement_execution_performed",
        "editing_software_opened"
      ],
      "properties": {
        "status": { "enum": ["PASSED", "NEEDS_REVIEW"] },
        "platform_count": { "type": "number" },
        "passed_platform_count": { "type": "number" },
        "instruction_count": { "type": "number" },
        "ready_pending_human_confirmation_count": { "type": "number" },
        "pending_human_media_count": { "type": "number" },
        "blocked_instruction_count": { "type": "number" },
        "executable_after_human_confirmation_count": { "type": "number" },
        "human_confirmation_required_count": { "type": "number" },
        "human_confirmation_gate_active": { "type": "boolean" },
        "replacement_execution_performed": { "type": "boolean", "const": false },
        "editing_software_opened": { "type": "boolean", "const": false }
      },
      "additionalProperties": false
    },
    "generation_status": {
      "type": "string",
      "const": "generated_local_editor_replacement_instruction_bundle_pending_human_confirmation"
    },
    "manual_review_required": { "type": "boolean", "const": true },
    "human_confirmation_required": { "type": "boolean", "const": true },
    "review_required": { "type": "boolean", "const": true }
  },
  "additionalProperties": false
}
