{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-agent-os.local/schemas/cover_image_metadata.schema.json",
  "title": "CoverImageMetadata",
  "type": "object",
  "required": [
    "schema_version",
    "asset_type",
    "platform",
    "platform_label",
    "path",
    "width",
    "height",
    "aspect_ratio",
    "adapter",
    "adapter_version",
    "generation_status",
    "rights_status",
    "manual_review_required",
    "source_prompt",
    "run_id",
    "review_notes"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "phase4.cover_image_metadata.v1" },
    "asset_type": { "type": "string", "const": "cover_image" },
    "platform": { "enum": ["douyin", "shipinhao", "bilibili"] },
    "platform_label": { "type": "string" },
    "path": { "type": "string" },
    "width": { "type": "number" },
    "height": { "type": "number" },
    "aspect_ratio": { "type": "string" },
    "adapter": { "type": "string" },
    "adapter_version": { "type": "string" },
    "generation_status": { "type": "string", "const": "generated_pending_review" },
    "rights_status": { "type": "string", "const": "pending_human_review" },
    "manual_review_required": { "type": "boolean", "const": true },
    "source_prompt": { "type": "string" },
    "run_id": { "type": "string" },
    "task_id": { "type": "string" },
    "source_artifacts": { "type": "array", "items": { "type": "string" } },
    "source_mode": { "type": ["string", "null"] },
    "source_provider": { "type": ["string", "null"] },
    "source_reference": { "type": ["string", "null"] },
    "source_library_root": { "type": ["string", "null"] },
    "source_content_type": { "type": ["string", "null"] },
    "source_revised_prompt": { "type": ["string", "null"] },
    "used_by": { "type": "array", "items": { "type": "string" } },
    "review_notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
