{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-agent-os.local/schemas/editor_software_real_runner_command_preview.schema.json",
  "title": "EditorSoftwareRealRunnerCommandPreview",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "topic",
    "platform",
    "platform_label",
    "command_preview_path",
    "commands",
    "summary",
    "export_boundary",
    "validation",
    "manual_review_required",
    "human_real_run_approval_required",
    "review_required"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "phase4.editor_software_real_runner_command_preview.v1" },
    "artifact_type": { "type": "string", "const": "editor_software_real_runner_command_preview" },
    "run_id": { "type": "string" },
    "topic": { "type": "string" },
    "platform": { "enum": ["douyin", "shipinhao", "bilibili"] },
    "platform_label": { "type": "string" },
    "command_preview_path": { "type": "string" },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command_id",
          "command_type",
          "manual_command_preview",
          "external_sandbox_required",
          "auto_execute",
          "dry_run_only",
          "real_software_launch_performed",
          "software_import_execution_performed",
          "editing_software_opened",
          "project_file_mutation_performed",
          "process_spawned",
          "upload_performed",
          "publishing_performed"
        ],
        "properties": {
          "command_id": { "type": "string" },
          "asset_id": { "type": "string" },
          "command_type": { "type": "string", "const": "editor_software_real_runner_sandbox" },
          "source_command_type": { "type": ["string", "null"] },
          "target_editor": { "type": "string" },
          "platform": { "enum": ["douyin", "shipinhao", "bilibili"] },
          "patched_project_path": { "type": "string" },
          "manual_command_preview": { "type": "string" },
          "external_sandbox_required": { "type": "boolean", "const": true },
          "human_real_run_approval_required": { "type": "boolean", "const": true },
          "human_real_run_approved": { "type": "boolean" },
          "manual_launch_ready": { "type": "boolean" },
          "auto_execute": { "type": "boolean", "const": false },
          "dry_run_only": { "type": "boolean", "const": true },
          "execution_status": { "type": "string" },
          "real_software_launch_performed": { "type": "boolean", "const": false },
          "software_import_execution_performed": { "type": "boolean", "const": false },
          "editing_software_opened": { "type": "boolean", "const": false },
          "project_file_mutation_performed": { "type": "boolean", "const": false },
          "process_spawned": { "type": "boolean", "const": false },
          "upload_performed": { "type": "boolean", "const": false },
          "publishing_performed": { "type": "boolean", "const": false }
        },
        "additionalProperties": false
      }
    },
    "summary": { "type": "object", "additionalProperties": true },
    "export_boundary": { "type": "object", "additionalProperties": true },
    "validation": { "type": "object", "additionalProperties": true },
    "manual_review_required": { "type": "boolean", "const": true },
    "human_real_run_approval_required": { "type": "boolean", "const": true },
    "review_required": { "type": "boolean", "const": true }
  },
  "additionalProperties": false
}
