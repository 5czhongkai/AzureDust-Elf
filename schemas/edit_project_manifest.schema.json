{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-agent-os.local/schemas/edit_project_manifest.schema.json",
  "title": "EditProjectManifest",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "topic",
    "platform",
    "platform_label",
    "adapter",
    "adapter_version",
    "timeline_path",
    "edl_path",
    "manifest_path",
    "duration_seconds",
    "frame_rate",
    "source_artifacts",
    "deliverables",
    "track_summary",
    "validation",
    "generation_status",
    "manual_review_required",
    "review_notes",
    "review_required"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "phase4.edit_project_manifest.v1" },
    "artifact_type": { "type": "string", "const": "edit_project" },
    "run_id": { "type": "string" },
    "topic": { "type": "string" },
    "platform": { "enum": ["douyin", "shipinhao", "bilibili"] },
    "platform_label": { "type": "string" },
    "adapter": { "type": "string", "const": "local-edit-project-adapter" },
    "adapter_version": { "type": "string" },
    "timeline_path": { "type": "string" },
    "edl_path": { "type": "string" },
    "manifest_path": { "type": "string" },
    "duration_seconds": { "type": "number" },
    "frame_rate": { "type": "number" },
    "source_artifacts": { "type": "array", "items": { "type": "string" } },
    "deliverables": {
      "type": "object",
      "required": ["timeline", "edl", "manifest"],
      "properties": {
        "timeline": { "type": "string" },
        "edl": { "type": "string" },
        "manifest": { "type": "string" }
      },
      "additionalProperties": false
    },
    "track_summary": {
      "type": "object",
      "required": ["video_clips", "audio_clips", "subtitle_clips", "markers"],
      "properties": {
        "video_clips": { "type": "number" },
        "audio_clips": { "type": "number" },
        "subtitle_clips": { "type": "number" },
        "markers": { "type": "number" }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "const": "PASSED" },
        "video_duration_matches": { "type": "boolean" },
        "audio_duration_matches": { "type": "boolean" },
        "subtitle_duration_matches": { "type": "boolean" },
        "video_clip_count": { "type": "number" },
        "audio_clip_count": { "type": "number" },
        "subtitle_clip_count": { "type": "number" }
      },
      "additionalProperties": false
    },
    "generation_status": {
      "type": "string",
      "const": "generated_local_edit_timeline_pending_human_review"
    },
    "manual_review_required": { "type": "boolean", "const": true },
    "review_notes": { "type": "array", "items": { "type": "string" } },
    "review_required": { "type": "boolean", "const": true }
  },
  "additionalProperties": false
}
