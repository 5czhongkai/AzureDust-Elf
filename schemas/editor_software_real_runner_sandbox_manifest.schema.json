{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-agent-os.local/schemas/editor_software_real_runner_sandbox_manifest.schema.json",
  "title": "EditorSoftwareRealRunnerSandboxManifest",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "topic",
    "platform",
    "platform_label",
    "adapter",
    "adapter_version",
    "manifest_path",
    "environment_snapshot_path",
    "launch_plan_path",
    "command_preview_path",
    "audit_log_path",
    "evidence_manifest_path",
    "approval_request_path",
    "readme_path",
    "source_import_manifest_path",
    "source_import_plan_path",
    "source_import_commands_path",
    "source_rollback_safety_report_path",
    "source_patched_project_path",
    "human_real_run_approval_path",
    "human_real_run_approval_present",
    "human_real_run_approval_valid",
    "target_editor",
    "runner_items",
    "summary",
    "source_artifacts",
    "export_boundary",
    "validation",
    "generation_status",
    "manual_review_required",
    "human_real_run_approval_required",
    "review_required"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "phase4.editor_software_real_runner_sandbox_manifest.v1" },
    "artifact_type": { "type": "string", "const": "editor_software_real_runner_sandbox" },
    "run_id": { "type": "string" },
    "topic": { "type": "string" },
    "platform": { "enum": ["douyin", "shipinhao", "bilibili"] },
    "platform_label": { "type": "string" },
    "adapter": { "type": "string", "const": "local-editor-software-real-runner-sandbox-adapter" },
    "adapter_version": { "type": "string" },
    "manifest_path": { "type": "string" },
    "environment_snapshot_path": { "type": "string" },
    "launch_plan_path": { "type": "string" },
    "command_preview_path": { "type": "string" },
    "audit_log_path": { "type": "string" },
    "evidence_manifest_path": { "type": "string" },
    "approval_request_path": { "type": "string" },
    "readme_path": { "type": "string" },
    "source_import_manifest_path": { "type": "string" },
    "source_import_plan_path": { "type": "string" },
    "source_import_commands_path": { "type": "string" },
    "source_rollback_safety_report_path": { "type": "string" },
    "source_patched_project_path": { "type": "string" },
    "human_real_run_approval_path": { "type": "string" },
    "human_real_run_approval_present": { "type": "boolean" },
    "human_real_run_approval_valid": { "type": "boolean" },
    "target_editor": { "type": "string" },
    "runner_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command_id",
          "asset_id",
          "source_import_status",
          "human_real_run_approved",
          "real_run_status",
          "real_software_launch_performed",
          "software_import_execution_performed",
          "editing_software_opened",
          "project_file_mutation_performed",
          "process_spawned",
          "upload_performed",
          "publishing_performed",
          "execution_mode"
        ],
        "properties": {
          "command_id": { "type": "string" },
          "asset_id": { "type": "string" },
          "shot_id": { "type": ["string", "null"] },
          "timeline_track": { "type": ["string", "null"] },
          "source_import_status": { "type": "string" },
          "patched_project_path": { "type": ["string", "null"] },
          "human_real_run_approved": { "type": "boolean" },
          "real_run_status": {
            "enum": [
              "blocked_pending_human_real_run_approval",
              "blocked_import_not_ready",
              "ready_for_manual_external_sandbox_launch"
            ]
          },
          "real_software_launch_performed": { "type": "boolean", "const": false },
          "software_import_execution_performed": { "type": "boolean", "const": false },
          "editing_software_opened": { "type": "boolean", "const": false },
          "project_file_mutation_performed": { "type": "boolean", "const": false },
          "process_spawned": { "type": "boolean", "const": false },
          "upload_performed": { "type": "boolean", "const": false },
          "publishing_performed": { "type": "boolean", "const": false },
          "execution_mode": { "type": "string", "const": "manual_external_sandbox_launch_only" }
        },
        "additionalProperties": false
      }
    },
    "summary": { "type": "object", "additionalProperties": true },
    "source_artifacts": { "type": "array", "items": { "type": "string" } },
    "export_boundary": {
      "type": "object",
      "required": [
        "editor_software_real_runner_sandbox",
        "real_software_launch",
        "software_import_execution",
        "editing_software",
        "project_file_mutation",
        "original_project_mutation",
        "replacement_execution",
        "requires_explicit_human_real_run_approval",
        "external_process_isolation",
        "process_spawn",
        "asset_download",
        "external_asset_search",
        "license_purchase",
        "upload",
        "publishing"
      ],
      "properties": {
        "editor_software_real_runner_sandbox": {
          "enum": [
            "blocked_pending_explicit_human_real_run_approval",
            "approved_for_manual_external_sandbox_launch_not_executed"
          ]
        },
        "real_software_launch": { "type": "string", "const": "not_performed" },
        "software_import_execution": { "type": "string", "const": "not_performed" },
        "editing_software": { "type": "string", "const": "not_opened" },
        "project_file_mutation": { "type": "string", "const": "not_performed_by_runner" },
        "original_project_mutation": { "type": "string", "const": "not_performed" },
        "replacement_execution": { "type": "string", "const": "not_performed" },
        "requires_explicit_human_real_run_approval": { "type": "boolean", "const": true },
        "external_process_isolation": { "type": "string", "const": "required_before_human_launch" },
        "process_spawn": { "type": "string", "const": "not_performed" },
        "asset_download": { "type": "string", "const": "not_performed" },
        "external_asset_search": { "type": "string", "const": "not_performed" },
        "license_purchase": { "type": "string", "const": "not_performed" },
        "upload": { "type": "string", "const": "not_performed" },
        "publishing": { "type": "string", "const": "not_performed" }
      },
      "additionalProperties": false
    },
    "validation": { "type": "object", "additionalProperties": true },
    "generation_status": {
      "type": "string",
      "const": "generated_local_editor_software_real_runner_sandbox_pending_explicit_human_launch"
    },
    "manual_review_required": { "type": "boolean", "const": true },
    "human_real_run_approval_required": { "type": "boolean", "const": true },
    "review_required": { "type": "boolean", "const": true }
  },
  "additionalProperties": false
}
