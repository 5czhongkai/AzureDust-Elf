{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-agent-os.local/schemas/artifact_manifest.schema.json",
  "title": "ArtifactManifest",
  "type": "object",
  "required": ["run_id", "artifacts"],
  "properties": {
    "run_id": { "type": "string" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind", "producer"],
        "properties": {
          "path": { "type": "string" },
          "kind": { "type": "string" },
          "producer": { "type": "string" },
          "description": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "execution_mode": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
