{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-agent-os.local/schemas/licensed_media_ingest_bundle_manifest.schema.json",
  "title": "LicensedMediaIngestBundleManifest",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "topic",
    "manifest_path",
    "video_production_package",
    "platforms",
    "source_artifacts",
    "platform_ingests",
    "export_boundary",
    "validation",
    "generation_status",
    "manual_review_required",
    "review_required"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "phase4.licensed_media_ingest_bundle_manifest.v1" },
    "artifact_type": { "type": "string", "const": "licensed_media_ingest_bundle" },
    "run_id": { "type": "string" },
    "topic": { "type": "string" },
    "manifest_path": { "type": "string", "const": "final/licensed_media_ingest_manifest.json" },
    "video_production_package": { "type": "string", "const": "final/video_production_package.json" },
    "platforms": {
      "type": "array",
      "items": { "enum": ["douyin", "shipinhao", "bilibili"] }
    },
    "source_artifacts": { "type": "array", "items": { "type": "string" } },
    "platform_ingests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "platform",
          "platform_label",
          "manifest_path",
          "readme_path",
          "review_handoff_path",
          "human_media_registry_path",
          "human_media_registry_exists",
          "required_final_media_count",
          "pending_human_media_count",
          "candidate_media_count",
          "ready_for_editor_replacement_count",
          "licensed_media_paths",
          "license_proof_paths",
          "validation",
          "source_artifacts",
          "review_required"
        ],
        "properties": {
          "platform": { "enum": ["douyin", "shipinhao", "bilibili"] },
          "platform_label": { "type": "string" },
          "manifest_path": { "type": ["string", "null"] },
          "readme_path": { "type": ["string", "null"] },
          "review_handoff_path": { "type": ["string", "null"] },
          "human_media_registry_path": { "type": ["string", "null"] },
          "human_media_registry_exists": { "type": "boolean" },
          "required_final_media_count": { "type": "number" },
          "pending_human_media_count": { "type": "number" },
          "candidate_media_count": { "type": "number" },
          "ready_for_editor_replacement_count": { "type": "number" },
          "licensed_media_paths": { "type": "array", "items": { "type": "string" } },
          "license_proof_paths": { "type": "array", "items": { "type": "string" } },
          "validation": {
            "type": "object",
            "required": ["status", "intake_complete", "licensed_final_media_required"],
            "properties": {
              "status": { "type": ["string", "null"] },
              "intake_complete": { "type": "boolean" },
              "licensed_final_media_required": { "type": "boolean" }
            },
            "additionalProperties": false
          },
          "source_artifacts": { "type": "array", "items": { "type": "string" } },
          "review_required": { "type": "boolean", "const": true }
        },
        "additionalProperties": false
      }
    },
    "export_boundary": {
      "type": "object",
      "required": [
        "licensed_media_ingest",
        "asset_download",
        "external_asset_search",
        "editing_software",
        "publishing",
        "upload"
      ],
      "properties": {
        "licensed_media_ingest": { "type": "string", "const": "review_handoff_only_pending_human_supplied_media" },
        "asset_download": { "type": "string", "const": "not_performed" },
        "external_asset_search": { "type": "string", "const": "not_performed" },
        "editing_software": { "type": "string", "const": "not_opened" },
        "publishing": { "type": "string", "const": "not_performed" },
        "upload": { "type": "string", "const": "not_performed" }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": [
        "status",
        "platform_count",
        "passed_platform_count",
        "required_final_media_count",
        "pending_human_media_count",
        "candidate_media_count",
        "ready_for_editor_replacement_count",
        "intake_complete",
        "licensed_final_media_required"
      ],
      "properties": {
        "status": { "type": "string" },
        "platform_count": { "type": "number" },
        "passed_platform_count": { "type": "number" },
        "required_final_media_count": { "type": "number" },
        "pending_human_media_count": { "type": "number" },
        "candidate_media_count": { "type": "number" },
        "ready_for_editor_replacement_count": { "type": "number" },
        "intake_complete": { "type": "boolean" },
        "licensed_final_media_required": { "type": "boolean", "const": true }
      },
      "additionalProperties": false
    },
    "generation_status": {
      "type": "string",
      "const": "generated_local_licensed_media_ingest_bundle_pending_human_review"
    },
    "manual_review_required": { "type": "boolean", "const": true },
    "review_required": { "type": "boolean", "const": true }
  },
  "additionalProperties": false
}
