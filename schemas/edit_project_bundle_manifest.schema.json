{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-agent-os.local/schemas/edit_project_bundle_manifest.schema.json",
  "title": "EditProjectBundleManifest",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "topic",
    "manifest_path",
    "video_production_package",
    "platforms",
    "source_artifacts",
    "platform_projects",
    "export_boundary",
    "validation",
    "generation_status",
    "manual_review_required",
    "review_required"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "phase4.edit_project_bundle_manifest.v1" },
    "artifact_type": { "type": "string", "const": "edit_project_bundle" },
    "run_id": { "type": "string" },
    "topic": { "type": "string" },
    "manifest_path": { "type": "string", "const": "final/edit_project_manifest.json" },
    "video_production_package": { "type": "string", "const": "final/video_production_package.json" },
    "platforms": {
      "type": "array",
      "items": { "enum": ["douyin", "shipinhao", "bilibili"] }
    },
    "source_artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "platform_projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "platform",
          "platform_label",
          "aspect_ratio",
          "duration_seconds",
          "frame_rate",
          "timeline_path",
          "manifest_path",
          "edl_path",
          "track_summary",
          "validation",
          "source_artifacts",
          "review_required"
        ],
        "properties": {
          "platform": { "enum": ["douyin", "shipinhao", "bilibili"] },
          "platform_label": { "type": "string" },
          "aspect_ratio": { "type": "string" },
          "duration_seconds": { "type": "number" },
          "frame_rate": { "type": "number" },
          "timeline_path": { "type": "string" },
          "manifest_path": { "type": "string" },
          "edl_path": { "type": "string" },
          "track_summary": { "type": "object", "additionalProperties": true },
          "validation": {
            "type": "object",
            "required": [
              "status",
              "video_duration_matches",
              "audio_duration_matches",
              "subtitle_duration_matches"
            ],
            "properties": {
              "status": { "type": ["string", "null"] },
              "video_duration_matches": { "type": "boolean" },
              "audio_duration_matches": { "type": "boolean" },
              "subtitle_duration_matches": { "type": "boolean" }
            },
            "additionalProperties": false
          },
          "source_artifacts": {
            "type": "array",
            "items": { "type": "string" }
          },
          "review_required": { "type": "boolean", "const": true }
        },
        "additionalProperties": false
      }
    },
    "export_boundary": {
      "type": "object",
      "required": ["edit_project_generation", "publishing", "upload"],
      "properties": {
        "edit_project_generation": { "type": "string" },
        "publishing": { "type": "string" },
        "upload": { "type": "string" }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": ["status", "platform_count", "passed_platform_count"],
      "properties": {
        "status": { "type": "string" },
        "platform_count": { "type": "number" },
        "passed_platform_count": { "type": "number" }
      },
      "additionalProperties": false
    },
    "generation_status": {
      "type": "string",
      "const": "generated_local_edit_timeline_bundle_pending_human_review"
    },
    "manual_review_required": { "type": "boolean", "const": true },
    "review_required": { "type": "boolean", "const": true }
  },
  "additionalProperties": false
}
