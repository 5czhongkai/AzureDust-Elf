{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-agent-os.local/schemas/project_bundle_bundle_manifest.schema.json",
  "title": "ProjectBundleBundleManifest",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "topic",
    "manifest_path",
    "video_production_package",
    "platforms",
    "source_artifacts",
    "platform_bundles",
    "export_boundary",
    "validation",
    "generation_status",
    "manual_review_required",
    "review_required"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "phase4.project_bundle_bundle_manifest.v1" },
    "artifact_type": { "type": "string", "const": "project_bundle_bundle" },
    "run_id": { "type": "string" },
    "topic": { "type": "string" },
    "manifest_path": { "type": "string", "const": "final/project_bundle_manifest.json" },
    "video_production_package": { "type": "string", "const": "final/video_production_package.json" },
    "platforms": {
      "type": "array",
      "items": { "enum": ["douyin", "shipinhao", "bilibili"] }
    },
    "source_artifacts": { "type": "array", "items": { "type": "string" } },
    "platform_bundles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "platform",
          "platform_label",
          "bundle_format",
          "bundle_path",
          "manifest_path",
          "file_manifest_path",
          "readme_path",
          "bundle_summary",
          "validation",
          "source_artifacts",
          "review_required"
        ],
        "properties": {
          "platform": { "enum": ["douyin", "shipinhao", "bilibili"] },
          "platform_label": { "type": "string" },
          "bundle_format": { "type": "string" },
          "bundle_path": { "type": "string" },
          "manifest_path": { "type": "string" },
          "file_manifest_path": { "type": "string" },
          "readme_path": { "type": "string" },
          "bundle_summary": { "type": "object", "additionalProperties": true },
          "validation": { "type": "object", "additionalProperties": true },
          "source_artifacts": { "type": "array", "items": { "type": "string" } },
          "review_required": { "type": "boolean", "const": true }
        },
        "additionalProperties": false
      }
    },
    "export_boundary": {
      "type": "object",
      "required": ["project_bundle_generation", "editing_software", "publishing", "upload"],
      "properties": {
        "project_bundle_generation": { "type": "string" },
        "editing_software": { "type": "string" },
        "publishing": { "type": "string" },
        "upload": { "type": "string" }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": ["status", "platform_count", "passed_platform_count"],
      "properties": {
        "status": { "type": "string" },
        "platform_count": { "type": "number" },
        "passed_platform_count": { "type": "number" }
      },
      "additionalProperties": false
    },
    "generation_status": { "type": "string", "const": "generated_local_project_bundle_bundle_pending_human_review" },
    "manual_review_required": { "type": "boolean", "const": true },
    "review_required": { "type": "boolean", "const": true }
  },
  "additionalProperties": false
}
