{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-agent-os.local/schemas/storyboard_preview_metadata.schema.json",
  "title": "StoryboardPreviewMetadata",
  "type": "object",
  "required": [
    "schema_version",
    "asset_type",
    "platform",
    "platform_label",
    "path",
    "width",
    "height",
    "aspect_ratio",
    "source_aspect_ratio",
    "adapter",
    "adapter_version",
    "generation_status",
    "rights_status",
    "manual_review_required",
    "run_id",
    "topic",
    "frame_count",
    "frames",
    "source_modes",
    "source_providers",
    "review_notes"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "phase4.storyboard_preview_metadata.v1" },
    "asset_type": { "type": "string", "const": "storyboard_preview" },
    "platform": { "enum": ["douyin", "shipinhao", "bilibili"] },
    "platform_label": { "type": "string" },
    "path": { "type": "string" },
    "width": { "type": "number" },
    "height": { "type": "number" },
    "aspect_ratio": { "type": "string" },
    "source_aspect_ratio": { "type": "string" },
    "adapter": { "type": "string" },
    "adapter_version": { "type": "string" },
    "generation_status": { "type": "string", "const": "generated_pending_review" },
    "rights_status": { "type": "string", "const": "pending_human_review" },
    "manual_review_required": { "type": "boolean", "const": true },
    "run_id": { "type": "string" },
    "topic": { "type": "string" },
    "frame_count": { "type": "number" },
    "source_modes": { "type": "array", "items": { "type": ["string", "null"] } },
    "source_providers": { "type": "array", "items": { "type": ["string", "null"] } },
    "frames": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "asset_type",
          "platform",
          "platform_label",
          "path",
          "width",
          "height",
          "aspect_ratio",
          "adapter",
          "adapter_version",
          "generation_status",
          "rights_status",
          "manual_review_required",
          "run_id",
          "frame_index",
          "shot_id",
          "linked_shot_id",
          "scene",
          "purpose",
          "duration_seconds",
          "source_visual",
          "source_voiceover",
          "review_notes"
        ],
        "properties": {
          "schema_version": { "type": "string", "const": "phase4.storyboard_frame_metadata.v1" },
          "asset_type": { "type": "string", "const": "storyboard_frame" },
          "platform": { "enum": ["douyin", "shipinhao", "bilibili"] },
          "platform_label": { "type": "string" },
          "path": { "type": "string" },
          "width": { "type": "number" },
          "height": { "type": "number" },
          "aspect_ratio": { "type": "string" },
          "adapter": { "type": "string" },
          "adapter_version": { "type": "string" },
          "generation_status": { "type": "string", "const": "generated_pending_review" },
          "rights_status": { "type": "string", "const": "pending_human_review" },
          "manual_review_required": { "type": "boolean", "const": true },
          "run_id": { "type": "string" },
          "topic": { "type": "string" },
          "frame_index": { "type": "number" },
          "shot_id": { "type": "string" },
          "linked_shot_id": { "type": "string" },
          "scene": { "type": "string" },
          "purpose": { "type": "string" },
          "duration_seconds": { "type": "number" },
          "source_visual": { "type": "string" },
          "source_voiceover": { "type": "string" },
          "source_topic": { "type": "string" },
          "task_id": { "type": ["string", "null"] },
          "source_prompt": { "type": ["string", "null"] },
          "source_mode": { "type": ["string", "null"] },
          "source_provider": { "type": ["string", "null"] },
          "source_reference": { "type": ["string", "null"] },
          "source_library_root": { "type": ["string", "null"] },
          "source_content_type": { "type": ["string", "null"] },
          "source_revised_prompt": { "type": ["string", "null"] },
          "source_artifacts": { "type": "array", "items": { "type": "string" } },
          "used_by": { "type": "array", "items": { "type": "string" } },
          "review_notes": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "source_artifacts": { "type": "array", "items": { "type": "string" } },
    "frame_paths": { "type": "array", "items": { "type": "string" } },
    "frame_task_ids": { "type": "array", "items": { "type": ["string", "null"] } },
    "used_by": { "type": "array", "items": { "type": "string" } },
    "review_required": { "type": "boolean", "const": true },
    "review_notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
