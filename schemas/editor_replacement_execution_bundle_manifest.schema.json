{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-agent-os.local/schemas/editor_replacement_execution_bundle_manifest.schema.json",
  "title": "EditorReplacementExecutionBundleManifest",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "topic",
    "manifest_path",
    "video_production_package",
    "platforms",
    "source_artifacts",
    "platform_executions",
    "export_boundary",
    "validation",
    "generation_status",
    "manual_review_required",
    "human_execution_approval_required",
    "review_required"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "phase4.editor_replacement_execution_bundle_manifest.v1" },
    "artifact_type": { "type": "string", "const": "editor_replacement_execution_bundle" },
    "run_id": { "type": "string" },
    "topic": { "type": "string" },
    "manifest_path": { "type": "string", "const": "final/editor_replacement_execution_manifest.json" },
    "video_production_package": { "type": "string", "const": "final/video_production_package.json" },
    "platforms": {
      "type": "array",
      "items": { "enum": ["douyin", "shipinhao", "bilibili"] }
    },
    "source_artifacts": { "type": "array", "items": { "type": "string" } },
    "platform_executions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "platform",
          "platform_label",
          "manifest_path",
          "execution_plan_path",
          "audit_log_path",
          "approval_request_path",
          "readme_path",
          "human_execution_approval_present",
          "human_execution_approval_valid",
          "command_count",
          "validation",
          "source_artifacts",
          "review_required",
          "human_execution_approval_required"
        ],
        "properties": {
          "platform": { "enum": ["douyin", "shipinhao", "bilibili"] },
          "platform_label": { "type": "string" },
          "manifest_path": { "type": ["string", "null"] },
          "execution_plan_path": { "type": ["string", "null"] },
          "audit_log_path": { "type": ["string", "null"] },
          "approval_request_path": { "type": ["string", "null"] },
          "readme_path": { "type": ["string", "null"] },
          "human_execution_approval_path": { "type": ["string", "null"] },
          "human_execution_approval_present": { "type": "boolean" },
          "human_execution_approval_valid": { "type": "boolean" },
          "command_count": { "type": "number" },
          "ready_after_instruction_gate_count": { "type": "number" },
          "human_execution_approved_count": { "type": "number" },
          "blocked_execution_count": { "type": "number" },
          "blocked_pending_approval_count": { "type": "number" },
          "blocked_proxy_media_missing_count": { "type": "number" },
          "executable_after_approval_count": { "type": "number" },
          "executed_count": { "type": "number" },
          "ready_asset_ids": { "type": "array", "items": { "type": "string" } },
          "approved_asset_ids": { "type": "array", "items": { "type": "string" } },
          "blocked_asset_ids": { "type": "array", "items": { "type": "string" } },
          "executable_asset_ids": { "type": "array", "items": { "type": "string" } },
          "validation": { "type": "object", "additionalProperties": true },
          "source_artifacts": { "type": "array", "items": { "type": "string" } },
          "review_required": { "type": "boolean", "const": true },
          "human_execution_approval_required": { "type": "boolean", "const": true }
        },
        "additionalProperties": false
      }
    },
    "export_boundary": {
      "type": "object",
      "required": [
        "editor_replacement_execution",
        "replacement_execution",
        "editing_software",
        "project_file_mutation",
        "requires_explicit_human_approval",
        "asset_download",
        "external_asset_search",
        "license_purchase",
        "publishing",
        "upload"
      ],
      "properties": {
        "editor_replacement_execution": {
          "enum": ["blocked_pending_explicit_human_approval", "approved_but_not_executed_by_default"]
        },
        "replacement_execution": { "type": "string", "const": "not_performed" },
        "editing_software": { "type": "string", "const": "not_opened" },
        "project_file_mutation": { "type": "string", "const": "not_performed" },
        "requires_explicit_human_approval": { "type": "boolean", "const": true },
        "asset_download": { "type": "string", "const": "not_performed" },
        "external_asset_search": { "type": "string", "const": "not_performed" },
        "license_purchase": { "type": "string", "const": "not_performed" },
        "publishing": { "type": "string", "const": "not_performed" },
        "upload": { "type": "string", "const": "not_performed" }
      },
      "additionalProperties": false
    },
    "validation": { "type": "object", "additionalProperties": true },
    "generation_status": {
      "type": "string",
      "const": "generated_local_execution_adapter_bundle_pending_explicit_human_approval"
    },
    "manual_review_required": { "type": "boolean", "const": true },
    "human_execution_approval_required": { "type": "boolean", "const": true },
    "review_required": { "type": "boolean", "const": true }
  },
  "additionalProperties": false
}
