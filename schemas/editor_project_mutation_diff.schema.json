{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-agent-os.local/schemas/editor_project_mutation_diff.schema.json",
  "title": "EditorProjectMutationDiff",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "topic",
    "platform",
    "platform_label",
    "manifest_path",
    "mutation_diff_path",
    "original_project_path",
    "patched_project_path",
    "mutations",
    "mutation_items",
    "summary",
    "export_boundary",
    "validation",
    "manual_review_required",
    "human_mutation_approval_required",
    "review_required"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "phase4.editor_project_mutation_diff.v1" },
    "artifact_type": { "type": "string", "const": "editor_project_mutation_diff" },
    "run_id": { "type": "string" },
    "topic": { "type": "string" },
    "platform": { "enum": ["douyin", "shipinhao", "bilibili"] },
    "platform_label": { "type": "string" },
    "manifest_path": { "type": "string" },
    "mutation_diff_path": { "type": "string" },
    "original_project_path": { "type": "string" },
    "patched_project_path": { "type": "string" },
    "mutations": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "mutation_items": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "summary": { "type": "object", "additionalProperties": true },
    "export_boundary": { "type": "object", "additionalProperties": true },
    "validation": { "type": "object", "additionalProperties": true },
    "manual_review_required": { "type": "boolean", "const": true },
    "human_mutation_approval_required": { "type": "boolean", "const": true },
    "review_required": { "type": "boolean", "const": true }
  },
  "additionalProperties": false
}
