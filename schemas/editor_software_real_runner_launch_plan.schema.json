{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-agent-os.local/schemas/editor_software_real_runner_launch_plan.schema.json",
  "title": "EditorSoftwareRealRunnerLaunchPlan",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "topic",
    "platform",
    "platform_label",
    "launch_plan_path",
    "sandbox_root",
    "source_patched_project_path",
    "runner_items",
    "launch_commands",
    "summary",
    "export_boundary",
    "validation",
    "manual_review_required",
    "human_real_run_approval_required",
    "review_required"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "phase4.editor_software_real_runner_launch_plan.v1" },
    "artifact_type": { "type": "string", "const": "editor_software_real_runner_launch_plan" },
    "run_id": { "type": "string" },
    "topic": { "type": "string" },
    "platform": { "enum": ["douyin", "shipinhao", "bilibili"] },
    "platform_label": { "type": "string" },
    "launch_plan_path": { "type": "string" },
    "sandbox_root": { "type": "string" },
    "source_patched_project_path": { "type": "string" },
    "runner_items": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "launch_commands": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "summary": { "type": "object", "additionalProperties": true },
    "export_boundary": { "type": "object", "additionalProperties": true },
    "validation": { "type": "object", "additionalProperties": true },
    "manual_review_required": { "type": "boolean", "const": true },
    "human_real_run_approval_required": { "type": "boolean", "const": true },
    "review_required": { "type": "boolean", "const": true }
  },
  "additionalProperties": false
}
