{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-agent-os.local/schemas/editor_project_mutation_bundle_manifest.schema.json",
  "title": "EditorProjectMutationBundleManifest",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "topic",
    "manifest_path",
    "video_production_package",
    "platforms",
    "source_artifacts",
    "platform_mutations",
    "export_boundary",
    "validation",
    "generation_status",
    "manual_review_required",
    "human_mutation_approval_required",
    "review_required"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "phase4.editor_project_mutation_bundle_manifest.v1" },
    "artifact_type": { "type": "string", "const": "editor_project_mutation_bundle" },
    "run_id": { "type": "string" },
    "topic": { "type": "string" },
    "manifest_path": { "type": "string", "const": "final/editor_project_mutation_manifest.json" },
    "video_production_package": { "type": "string", "const": "final/video_production_package.json" },
    "platforms": {
      "type": "array",
      "items": { "enum": ["douyin", "shipinhao", "bilibili"] }
    },
    "source_artifacts": { "type": "array", "items": { "type": "string" } },
    "platform_mutations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "platform",
          "platform_label",
          "manifest_path",
          "patched_project_path",
          "mutation_diff_path",
          "rollback_manifest_path",
          "audit_log_path",
          "final_review_checklist_path",
          "readme_path",
          "human_mutation_approval_present",
          "human_mutation_approval_valid",
          "execution_item_count",
          "mutation_applied_count",
          "blocked_mutation_count",
          "validation",
          "source_artifacts",
          "review_required",
          "human_mutation_approval_required"
        ],
        "properties": {
          "platform": { "enum": ["douyin", "shipinhao", "bilibili"] },
          "platform_label": { "type": "string" },
          "manifest_path": { "type": ["string", "null"] },
          "patched_project_path": { "type": ["string", "null"] },
          "mutation_diff_path": { "type": ["string", "null"] },
          "rollback_manifest_path": { "type": ["string", "null"] },
          "audit_log_path": { "type": ["string", "null"] },
          "final_review_checklist_path": { "type": ["string", "null"] },
          "readme_path": { "type": ["string", "null"] },
          "source_execution_manifest_path": { "type": ["string", "null"] },
          "source_execution_plan_path": { "type": ["string", "null"] },
          "source_export_manifest_path": { "type": ["string", "null"] },
          "source_project_path": { "type": ["string", "null"] },
          "human_mutation_approval_path": { "type": ["string", "null"] },
          "human_mutation_approval_present": { "type": "boolean" },
          "human_mutation_approval_valid": { "type": "boolean" },
          "execution_item_count": { "type": "number" },
          "mutation_applied_count": { "type": "number" },
          "blocked_mutation_count": { "type": "number" },
          "blocked_pending_approval_count": { "type": "number" },
          "blocked_execution_not_ready_count": { "type": "number" },
          "blocked_proxy_media_missing_count": { "type": "number" },
          "target_missing_count": { "type": "number" },
          "mutated_asset_ids": { "type": "array", "items": { "type": "string" } },
          "blocked_asset_ids": { "type": "array", "items": { "type": "string" } },
          "validation": { "type": "object", "additionalProperties": true },
          "source_artifacts": { "type": "array", "items": { "type": "string" } },
          "review_required": { "type": "boolean", "const": true },
          "human_mutation_approval_required": { "type": "boolean", "const": true }
        },
        "additionalProperties": false
      }
    },
    "export_boundary": {
      "type": "object",
      "required": [
        "editor_project_mutation_sandbox",
        "original_project_mutation",
        "sandbox_project_mutation",
        "replacement_execution",
        "editing_software",
        "project_file_mutation",
        "requires_explicit_human_mutation_approval",
        "asset_download",
        "external_asset_search",
        "license_purchase",
        "publishing",
        "upload"
      ],
      "properties": {
        "editor_project_mutation_sandbox": {
          "enum": [
            "blocked_pending_explicit_human_mutation_approval",
            "sandbox_patch_generated_from_explicit_human_approval"
          ]
        },
        "original_project_mutation": { "type": "string", "const": "not_performed" },
        "sandbox_project_mutation": { "enum": ["not_performed", "performed_on_patched_copy_only"] },
        "replacement_execution": { "type": "string", "const": "not_performed" },
        "editing_software": { "type": "string", "const": "not_opened" },
        "project_file_mutation": { "type": "string", "const": "patched_copy_only_original_not_mutated" },
        "requires_explicit_human_mutation_approval": { "type": "boolean", "const": true },
        "asset_download": { "type": "string", "const": "not_performed" },
        "external_asset_search": { "type": "string", "const": "not_performed" },
        "license_purchase": { "type": "string", "const": "not_performed" },
        "publishing": { "type": "string", "const": "not_performed" },
        "upload": { "type": "string", "const": "not_performed" }
      },
      "additionalProperties": false
    },
    "validation": { "type": "object", "additionalProperties": true },
    "generation_status": {
      "type": "string",
      "const": "generated_local_project_mutation_bundle_pending_final_human_review"
    },
    "manual_review_required": { "type": "boolean", "const": true },
    "human_mutation_approval_required": { "type": "boolean", "const": true },
    "review_required": { "type": "boolean", "const": true }
  },
  "additionalProperties": false
}
