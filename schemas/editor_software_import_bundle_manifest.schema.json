{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-agent-os.local/schemas/editor_software_import_bundle_manifest.schema.json",
  "title": "EditorSoftwareImportBundleManifest",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "topic",
    "manifest_path",
    "video_production_package",
    "platforms",
    "source_artifacts",
    "platform_imports",
    "export_boundary",
    "validation",
    "generation_status",
    "manual_review_required",
    "human_software_import_approval_required",
    "review_required"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "phase4.editor_software_import_bundle_manifest.v1" },
    "artifact_type": { "type": "string", "const": "editor_software_import_bundle" },
    "run_id": { "type": "string" },
    "topic": { "type": "string" },
    "manifest_path": { "type": "string", "const": "final/editor_software_import_manifest.json" },
    "video_production_package": { "type": "string", "const": "final/video_production_package.json" },
    "platforms": {
      "type": "array",
      "items": { "enum": ["douyin", "shipinhao", "bilibili"] }
    },
    "source_artifacts": { "type": "array", "items": { "type": "string" } },
    "platform_imports": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "platform",
          "platform_label",
          "manifest_path",
          "import_plan_path",
          "import_commands_path",
          "audit_log_path",
          "rollback_safety_report_path",
          "execution_request_path",
          "readme_path",
          "human_software_import_approval_present",
          "human_software_import_approval_valid",
          "target_editor",
          "import_item_count",
          "validation",
          "source_artifacts",
          "review_required",
          "human_software_import_approval_required"
        ],
        "properties": {
          "platform": { "enum": ["douyin", "shipinhao", "bilibili"] },
          "platform_label": { "type": "string" },
          "manifest_path": { "type": ["string", "null"] },
          "import_plan_path": { "type": ["string", "null"] },
          "import_commands_path": { "type": ["string", "null"] },
          "audit_log_path": { "type": ["string", "null"] },
          "rollback_safety_report_path": { "type": ["string", "null"] },
          "execution_request_path": { "type": ["string", "null"] },
          "readme_path": { "type": ["string", "null"] },
          "source_mutation_manifest_path": { "type": ["string", "null"] },
          "source_mutation_diff_path": { "type": ["string", "null"] },
          "source_rollback_manifest_path": { "type": ["string", "null"] },
          "source_patched_project_path": { "type": ["string", "null"] },
          "human_software_import_approval_path": { "type": ["string", "null"] },
          "human_software_import_approval_present": { "type": "boolean" },
          "human_software_import_approval_valid": { "type": "boolean" },
          "target_editor": { "type": ["string", "null"] },
          "import_item_count": { "type": "number" },
          "ready_for_isolated_manual_import_count": { "type": "number" },
          "blocked_import_count": { "type": "number" },
          "blocked_pending_approval_count": { "type": "number" },
          "blocked_no_sandbox_patch_count": { "type": "number" },
          "blocked_patched_project_missing_count": { "type": "number" },
          "executed_count": { "type": "number" },
          "editing_software_opened_count": { "type": "number" },
          "ready_asset_ids": { "type": "array", "items": { "type": "string" } },
          "blocked_asset_ids": { "type": "array", "items": { "type": "string" } },
          "validation": { "type": "object", "additionalProperties": true },
          "source_artifacts": { "type": "array", "items": { "type": "string" } },
          "review_required": { "type": "boolean", "const": true },
          "human_software_import_approval_required": { "type": "boolean", "const": true }
        },
        "additionalProperties": false
      }
    },
    "export_boundary": {
      "type": "object",
      "required": [
        "editor_software_import_executor",
        "software_import_execution",
        "editing_software",
        "project_file_mutation",
        "original_project_mutation",
        "replacement_execution",
        "requires_explicit_human_software_import_approval",
        "external_software_isolation",
        "asset_download",
        "external_asset_search",
        "license_purchase",
        "publishing",
        "upload"
      ],
      "properties": {
        "editor_software_import_executor": {
          "enum": [
            "blocked_pending_explicit_human_software_import_approval",
            "approved_for_isolated_manual_import_not_executed"
          ]
        },
        "software_import_execution": { "type": "string", "const": "not_performed" },
        "editing_software": { "type": "string", "const": "not_opened" },
        "project_file_mutation": { "type": "string", "const": "not_performed_by_executor" },
        "original_project_mutation": { "type": "string", "const": "not_performed" },
        "replacement_execution": { "type": "string", "const": "not_performed" },
        "requires_explicit_human_software_import_approval": { "type": "boolean", "const": true },
        "external_software_isolation": { "type": "string", "const": "required_before_manual_launch" },
        "asset_download": { "type": "string", "const": "not_performed" },
        "external_asset_search": { "type": "string", "const": "not_performed" },
        "license_purchase": { "type": "string", "const": "not_performed" },
        "publishing": { "type": "string", "const": "not_performed" },
        "upload": { "type": "string", "const": "not_performed" }
      },
      "additionalProperties": false
    },
    "validation": { "type": "object", "additionalProperties": true },
    "generation_status": {
      "type": "string",
      "const": "generated_local_editor_software_import_bundle_pending_explicit_human_launch"
    },
    "manual_review_required": { "type": "boolean", "const": true },
    "human_software_import_approval_required": { "type": "boolean", "const": true },
    "review_required": { "type": "boolean", "const": true }
  },
  "additionalProperties": false
}
