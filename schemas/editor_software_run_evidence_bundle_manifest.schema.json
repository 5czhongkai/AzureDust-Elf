{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-agent-os.local/schemas/editor_software_run_evidence_bundle_manifest.schema.json",
  "title": "EditorSoftwareRunEvidenceBundleManifest",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "topic",
    "manifest_path",
    "video_production_package",
    "platforms",
    "source_artifacts",
    "platform_evidence",
    "export_boundary",
    "validation",
    "generation_status",
    "manual_review_required",
    "human_real_run_result_required",
    "review_required"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "phase4.editor_software_run_evidence_bundle_manifest.v1" },
    "artifact_type": { "type": "string", "const": "editor_software_run_evidence_bundle" },
    "run_id": { "type": "string" },
    "topic": { "type": "string" },
    "manifest_path": { "type": "string", "const": "final/editor_software_run_evidence_manifest.json" },
    "video_production_package": { "type": "string", "const": "final/video_production_package.json" },
    "platforms": {
      "type": "array",
      "items": { "enum": ["douyin", "shipinhao", "bilibili"] }
    },
    "source_artifacts": { "type": "array", "items": { "type": "string" } },
    "platform_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "platform",
          "platform_label",
          "manifest_path",
          "human_real_run_result_present",
          "human_real_run_result_valid",
          "evidence_item_count",
          "validation",
          "source_artifacts",
          "review_required",
          "human_real_run_result_required"
        ],
        "properties": {
          "platform": { "enum": ["douyin", "shipinhao", "bilibili"] },
          "platform_label": { "type": "string" },
          "manifest_path": { "type": ["string", "null"] },
          "validation_report_path": { "type": ["string", "null"] },
          "rollback_decision_report_path": { "type": ["string", "null"] },
          "checklist_path": { "type": ["string", "null"] },
          "readme_path": { "type": ["string", "null"] },
          "human_real_run_result_path": { "type": ["string", "null"] },
          "human_real_run_result_present": { "type": "boolean" },
          "human_real_run_result_valid": { "type": "boolean" },
          "editor_software_run_evidence": { "type": ["string", "null"] },
          "evidence_item_count": { "type": "number" },
          "human_real_run_evidence_ingested_count": { "type": "number" },
          "blocked_evidence_count": { "type": "number" },
          "rollback_required_count": { "type": "number" },
          "rollback_decision": { "type": ["string", "null"] },
          "evidence_files": { "type": "array", "items": { "type": "string" } },
          "missing_evidence_files": { "type": "array", "items": { "type": "string" } },
          "validation": { "type": "object", "additionalProperties": true },
          "source_artifacts": { "type": "array", "items": { "type": "string" } },
          "review_required": { "type": "boolean", "const": true },
          "human_real_run_result_required": { "type": "boolean", "const": true }
        },
        "additionalProperties": true
      }
    },
    "export_boundary": { "type": "object", "additionalProperties": true },
    "validation": { "type": "object", "additionalProperties": true },
    "generation_status": { "type": "string" },
    "manual_review_required": { "type": "boolean", "const": true },
    "human_real_run_result_required": { "type": "boolean", "const": true },
    "review_required": { "type": "boolean", "const": true }
  },
  "additionalProperties": false
}
